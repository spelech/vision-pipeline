{
  "name": "vision-pipeline",
  "version": "3.6.9",
  "description": "An automated product identification and enrichment system that bridges physical items with digital home services.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "echo \"Use Python pytest or web Vitest directly\"",
    "test:e2e": "playwright test",
    "test:e2e:coverage": "node scripts/run-playwright-with-coverage.mjs",
    "coverage:web:check-regression": "node scripts/check-frontend-coverage-regression.mjs",
    "db:migrations:check": "python scripts/check_db_migrations.py",
    "db:migrations:create": "python scripts/create_db_migration.py",
    "deploy:smoke": "python scripts/smoke_deploy.py",
    "docs:test-index": "node scripts/update-test-requirements-index.mjs",
    "docs:test-index:check": "node scripts/update-test-requirements-index.mjs --check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spelech/vision-pipeline.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/spelech/vision-pipeline/issues"
  },
  "homepage": "https://github.com/spelech/vision-pipeline#readme",
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
