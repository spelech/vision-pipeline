[MASTER]
ignore-patterns=test_.*\.py
ignore-paths=src/migrations/.*

[MESSAGES CONTROL]
disable=
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    too-few-public-methods,
    duplicate-code

[FORMAT]
max-line-length=100

[TYPECHECK]
ignored-modules=pyzbar
