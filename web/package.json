{
  "name": "web",
  "private": true,
  "version": "3.6.20",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:tests": "eslint --no-config-lookup --config eslint.config.js \"src/**/*.{test,spec}.{ts,tsx}\"",
    "test": "vitest",
    "test:coverage": "vitest run --coverage.enabled",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:coverage": "node ../scripts/run-playwright-with-coverage.mjs web",
    "coverage:check-regression": "node ../scripts/check-frontend-coverage-regression.mjs",
    "docs:test-index": "node ../scripts/update-test-requirements-index.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.25",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.16.0",
    "postcss": "^8.5.15",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  }
}
