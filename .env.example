# --- CORE ---
# The port the application will be available on
APP_PORT=8460

# --- DEPLOY / IMAGE ---
# Image used by docker-compose for the main app service.
VISION_PIPELINE_IMAGE=ghcr.io/spelech/vision-pipeline
# Tag used by docker-compose and What's Up Docker (WUD) monitoring.
VISION_PIPELINE_TAG=latest

# Used to encrypt/decrypt secrets stored in the database. 
# Auto-generated by setup.sh if not provided.
ENCRYPTION_KEY=

# --- DATABASE ---
DB_USER=vision
DB_PASSWORD=vision_pass
DB_NAME=vision_pipeline
# For local docker: postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}
DATABASE_URL=postgresql+asyncpg://vision:vision_pass@db:5432/vision_pipeline

# --- VISION / LLM ---
# Get your key at https://openrouter.ai/
OPENROUTER_API_KEY=

# --- ENRICHMENT ---
# Local or remote SearxNG instance
SEARXNG_URL=

# --- INTEGRATIONS ---
# Homebox
HOMEBOX_URL=http://homebox:7745/api/v1
HOMEBOX_API_KEY=
# If you don't use API keys, provide Email/Password instead:
HOMEBOX_EMAIL=
HOMEBOX_PASSWORD=

# Mealie
MEALIE_URL=
MEALIE_API_TOKEN=

# PriceBuddy
PRICEBUDDY_URL=
PRICEBUDDY_API_KEY=

# ChangeDetection.io
CHANGEDETECTION_URL=
CHANGEDETECTION_API_KEY=

# --- NETWORK ---
# If deploying behind SWAG/Reverse Proxy on the main server, set this to true
EXTERNAL_NETWORK_EXISTS=false
EXTERNAL_NETWORK=net_webservices
