{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Docker: Build",
			"type": "shell",
			"command": "docker compose build",
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Docker: Up",
			"type": "shell",
			"command": "docker compose up -d",
			"group": "none",
			"problemMatcher": []
		},
		{
			"label": "Docker: Up (Remote)",
			"type": "shell",
			"command": "docker compose --env-file .env.remote up -d",
			"group": "none",
			"problemMatcher": []
		},
		{
			"label": "Docker: DB Up",
			"type": "shell",
			"command": "docker compose up -d db",
			"group": "none",
			"problemMatcher": []
		},
		{
			"label": "Docker: Down",
			"type": "shell",
			"command": "docker compose down",
			"group": "none",
			"problemMatcher": []
		},
		{
			"label": "Python: Install Requirements",
			"type": "shell",
			"command": "${command:python.interpreterPath} -m pip install -r src/requirements.txt",
			"problemMatcher": []
		},
		{
			"label": "Python: Run Tests",
			"type": "shell",
			"command": "node scripts/update-test-requirements-index.mjs && ${command:python.interpreterPath} -m pytest src/tests",
			"group": "test",
			"problemMatcher": []
		},
		{
			"label": "Python: Lint",
			"type": "shell",
			"command": "${command:python.interpreterPath} -m pylint src",
			"problemMatcher": [
				"$pylint"
			]
		},
		{
			"label": "Python: Typecheck",
			"type": "shell",
			"command": "${command:python.interpreterPath} -m mypy src",
			"problemMatcher": [
				"$mypy"
			]
		},
		{
			"label": "Python: DB Migration Drift Check",
			"type": "shell",
			"command": "${command:python.interpreterPath} scripts/check_db_migrations.py",
			"problemMatcher": []
		},
		{
			"label": "Python: DB Migration Upgrade",
			"type": "shell",
			"command": "docker compose exec -T vision-pipeline python -m alembic -c alembic.ini upgrade head",
			"problemMatcher": []
		},
		{
			"label": "Cleanup old files",
			"type": "shell",
			"command": "rm -rf src/templates src/.nicegui src/test_output.py"
		},
		{
			"label": "Debug: Full Stack",
			"dependsOn": [
				"Debug: Start Server (Docker)",
				"Vite: Dev (web)"
			],
			"problemMatcher": []
		},
		{
			"label": "Prep: Local Dev (DB + Web)",
			"dependsOn": [
				"Docker: DB Up",
				"Vite: Dev (web)"
			],
			"problemMatcher": []
		},
		{
			"label": "Debug: Start Server (Docker)",
			"type": "shell",
			"command": "bash scripts/start-debug.sh",
			"group": "none",
			"problemMatcher": []
		},
		{
			"label": "Vite: Dev (web)",
			"type": "shell",
			"command": "npm run dev",
			"options": {
				"cwd": "${workspaceFolder}/web"
			},
			"isBackground": true,
			"problemMatcher": [
				{
					"owner": "typescript",
					"fileLocation": "relative",
					"pattern": {
						"regexp": "^([^\\s].*)\\((\\d+|\\d+,\\d+|\\d+,\\d+,\\d+,\\d+)\\):\\s+(error|warning|info)\\s+(TS\\d+)\\s*:\\s*(.*)$",
						"file": 1,
						"location": 2,
						"severity": 3,
						"code": 4,
						"message": 5
					},
					"background": {
						"activeOnStart": true,
						"beginsPattern": "^\\s*VITE v",
						"endsPattern": "ready in \\d+ ms$"
					}
				}
			]
		},
		{
			"label": "Vite: Dev (web) cmd fallback",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev"
			],
			"isBackground": true,
			"group": "none"
		},
		{
			"label": "Vite: Dev (web) cmd fallback 2",
			"type": "shell",
			"command": "cd web && npm run dev",
			"isBackground": true,
			"group": "none"
		}
	]
}