{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: FastAPI (Local)",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8501",
                "--reload"
            ],
            "cwd": "${workspaceFolder}/src",
            "jinja": true,
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Python: Current File",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Docker: Python - Fastapi",
            "type": "docker",
            "request": "launch",
            "preLaunchTask": "Docker: Up",
            "python": {
                "pathMappings": [
                    {
                        "localRoot": "${workspaceFolder}/src",
                        "remoteRoot": "/app"
                    }
                ],
                "projectType": "fastapi"
            },
            "dockerCompose": {
                "files": [
                    "docker-compose.yaml"
                ],
                "service": "vision-pipeline"
            }
        }
    ]
}
